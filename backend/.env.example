NODE_ENV=development
PORT=4000

# MongoDB connection string — use a strong password in production
MONGO_URI=mongodb+srv://marwankhaj_db_user:yMS8LmXbdww0rHcR@cluster0.izur7u9.mongodb.net/

# JWT secrets — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_64_chars

# Access token expires in 15 minutes; refresh in 7 days
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# File upload directory (relative to project root)
UPLOAD_DIR=uploads

# Max file size in bytes (default 20 MB)
MAX_FILE_SIZE=20971520

# File encryption key — generate with: openssl rand -hex 32
FILE_ENC_KEY=CHANGE_ME_32_byte_hex_encryption_key_here

# Allowed CORS origin
CORS_ORIGIN=http://localhost:5173

# Bcrypt rounds (10–12 is standard; higher = slower = more secure)
BCRYPT_ROUNDS=12
